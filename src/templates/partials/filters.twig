{# @params sectionConfig, filters, orderByOptions #}
{# @var sectionConfig \wsydney76\contentoverview\models\Section #}

{% import '_includes/forms' as forms %}

{% for filter in filters %}

    <div>

        {% set name = "#{sectionPath}-filter" %}

        {% if filter.useElementSelect %}

            {% set elementSelectId = (name ~ '-elementSelect-' ~ filter.handle)|replace('.', '-')|id %}
            {% set filterInputId = (name ~ '-elementInput-' ~ filter.handle)|replace('.', '-')|id %}

            {% set searchCriteria = null %}
            {% if filter.searchCriteria %}

                {% set searchCriteria = filter.searchCriteria %}

            {% elseif filter.useElementSelectSearch %}

                {% set sources = filter.field.sources %}
                {% if sources|length == 1 %}
                    {% set parts = sources[0]|split(':') %}
                    {% if parts|length == 2 and parts[0] == 'section' %}
                        {% set section = craft.app.entries.sectionByUid(parts[1]) %}
                        {% if section %}
                            {% set searchCriteria = {
                                sectionId: section.id,
                                editable: null
                            } %}
                        {% endif %}
                    {% endif %}
                {% endif %}
            {% endif %}

            {# Hidden input that lets us handle an elementSelect like a select input  #}
            {# Value is set via JavaScript #}
            {{ forms.hidden({
                id: filterInputId,
                name: name,
                inputAttributes: {
                    data: {
                        'handle': filter.handle
                    }
                }
            }) }}


            {{ forms.elementSelect({
                id: elementSelectId,
                name: "#{sectionPath}-elementIds-#{filter.handle}",
                elementType: filter.elementType,
                sources: filter.getSources(),
                selectionLabel: 'Filter by'|t('contentoverview') ~ ': ' ~ filter.getLabel|t('site'), value: '',
                limit: filter.selectLimit,
                single: filter.selectLimit == 1,
                searchCriteria: searchCriteria,
                criteria: {siteId: filter.requestedSiteId}
            }) }}


            {# Listen for change events, update our hidden input and refresh section html #}
            {% js %}
            co_registerElementSelect('{{ elementSelectId }}', '{{ filterInputId }}', '{{ sectionPath }}')
            {% endjs %}

        {% else %}

            {% set emptyLabel = 'Filter by'|t('contentoverview') ~ ': ' ~ filter.getLabel|t('site') %}

            {% set config = {
                name: name,
                options: filter.getOptions()
                    .prepend({label: emptyLabel, value: ''}),
                inputAttributes: {
                    data: {
                        'handle': filter.handle
                    },
                    onchange: "co_getSectionHtml('#{ sectionPath }')"
                }
            } %}

            {% if filter.useSelectize %}
                 {% set config = config|merge(
                    {selectizeOptions: {
                        allowEmptyOption: true,
                        placeholder: emptyLabel,
                        plugins: ['clear_button']
                    }}) %}
                {{ forms.selectize(config) }}
            {% else %}
                {{ forms.select(config) }}
            {% endif %}
        {% endif %}


    </div>
{% endfor %}

